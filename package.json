{
  "name": "@g2crowd/elevate",
  "version": "0.1.0",
  "description": "G2 Elevate design system — Tailwind CSS theme, component styles, and design tokens",
  "license": "UNLICENSED",
  "private": true,
  "main": "./src/index.js",
  "exports": {
    ".": "./src/index.js",
    "./css": "./dist/elevate.css",
    "./theme": "./src/theme/index.js",
    "./theme/*": "./src/theme/*.js",
    "./tailwind": "./src/tailwind.config.js",
    "./tailwind.config": "./src/tailwind.config.js"
  },
  "files": [
    "src",
    "dist"
  ],
  "scripts": {
    "build": "yarn build:css",
    "build:css": "postcss src/css/application.css -o dist/elevate.css",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist",
    "examples": "yarn build && open examples/index.html"
  },
  "dependencies": {
    "tailwindcss-scoped-preflight": "^3.0.0"
  },
  "peerDependencies": {
    "tailwindcss": "^3.4.0"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.20",
    "happy-dom": "^20.0.2",
    "postcss": "^8.4.41",
    "postcss-cli": "^11.0.0",
    "postcss-import": "^16.1.0",
    "tailwindcss": "^3.4.10",
    "vitest": "^2.1.0"
  },
  "packageManager": "yarn@4.13.0"
}
